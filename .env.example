# ============================================================
#  File cấu hình Kubernetes setups (CentOS/RHEL 9 - K8s v1.29)
# ============================================================
#  Cách dùng:
#    1. Copy file này thành .env:   cp .env.example .env
#    2. Sửa các giá trị bên dưới cho đúng môi trường của bạn.
#    3. Chạy:  sudo bash install-master.sh   (hoặc install-worker.sh)
#
#  Quy tắc:
#    - Mỗi biến một dòng theo định dạng  KEY=value
#    - Dòng bắt đầu bằng # là comment, bị bỏ qua
#    - Không dùng dấu ngoặc quanh value (trừ khi value có khoảng trắng)
#    - Biến truyền trực tiếp qua lệnh (MASTER_IP=... bash script.sh)
#      sẽ GHI ĐÈ giá trị trong file .env này.
#    - Có thể chỉ định file khác: ENV_FILE=/path/file sudo bash install-master.sh
# ============================================================

# ---- Chung (cả master & worker) ----
# Thư mục lưu dữ liệu etcd / container (nên nằm trên ổ đủ dung lượng)
DATA_DIR=/data/k8s
# Hostname node (mặc định lấy hostname hiện tại nếu để trống)
NODE_HOSTNAME=

# ---- Chỉ cho MASTER ----
# IP dùng để advertise API server (IP của node master, worker sẽ kết nối tới)
MASTER_IP=10.0.0.10
# Dải mạng pod (phải khớp với CNI flannel)
POD_SUBNET=10.244.0.0/16
# Phiên bản Kubernetes
K8S_VERSION=v1.29.0

# ---- Chỉ cho WORKER ----
# Cách A: dán nguyên lệnh join lấy từ master (/root/k8s-join-command.sh)
#   Ví dụ: JOIN_CMD="kubeadm join 10.0.0.10:6443 --token abc123 --discovery-token-ca-cert-hash sha256:def456"
JOIN_CMD=
# Cách B: truyền từng phần (dùng nếu không có JOIN_CMD)
#   Lưu ý: token mặc định hết hạn sau 2h. Lấy mới: kubeadm token create --print-join-command
TOKEN=
HASH=
